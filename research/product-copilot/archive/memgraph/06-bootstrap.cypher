// ---- Suggested conventions ----
// 1. Use MERGE by stable id during ingestion.
// 2. Keep provenance fields on nodes even when also captured in source documents.
// 3. Use validation queries after import to catch ontology drift.
// 4. If text search is needed, add it separately using the search capabilities of your Memgraph version or an external retrieval layer.

// ---- Suggested ingest pattern ----
// MERGE (n:Requirement {id: $id})
// SET n += $props, n.updated_at = localDateTime()
// WITH n
// MATCH (g:Goal {id: $goal_id})
// MERGE (g)-[:DRIVES]->(n);

// ---- Sanity checks ----
// SHOW CONSTRAINT INFO;
// SHOW INDEX INFO;
// MATCH (n) RETURN labels(n) AS labels, count(*) AS c ORDER BY c DESC;