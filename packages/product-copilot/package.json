{
  "name": "product-copilot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Product Copilot pi extension scaffold with a LadybugDB-oriented local runtime layout.",
  "scripts": {
    "build": "echo 'No build step configured. pi loads the extension via jiti.'",
    "clean": "echo 'Nothing to clean yet.'",
    "format": "biome check --write .",
    "lint": "biome check . --error-on-warnings",
    "smoke:load": "tsx src/scripts/smoke-load.ts",
    "typecheck:src": "tsc -p tsconfig.json",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "typecheck": "npm run typecheck:src && npm run typecheck:test",
    "test": "tsx --test",
    "test:watch": "tsx --test --watch",
    "knip": "knip --max-show-issues 20",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run knip",
    "check": "npm run validate"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "@ladybugdb/core": "^0.15.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/node": "^22.19.17",
    "knip": "^6.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
